# ─────────────────────────────────────────────────────────────
# Bella MCP Server — Environment Variables
# Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Notion ─────────────────────────────────────────────────────

# Main workspace
NOTION_MAIN_WORKSPACE=2db92e6818f881a0b17dd5cf1e791d05

# Quarterly pages
NOTION_Q1=2db92e6818f880a1a5c9dc88077dd777
NOTION_Q2=2db92e6818f880418f49f3f37a6a6e37
NOTION_Q3=2db92e6818f88060865bc5ad8ab94b62
NOTION_Q4=2db92e6818f880c78004c9a8a22c128e

# Current month
NOTION_CURRENT_MONTH=2db92e6818f8816b9b86de1967627c92

# Databases
NOTION_TASKS_DB=31d92e6818f880bba9f9de2f8ea337ab
NOTION_PROJECTS_DB=31d92e6818f880cc952fd897f41f984c
NOTION_PAPER_READING_DB=33592e6818f880ecbd1ad8ed645e401a

# Key pages
NOTION_RESEARCH_PAPER=33792e6818f88143bfffd59a5557524d
NOTION_TEXT_COMPLAINT_APRIL=33592e6818f8804f9ed1c97bdadc8db7
NOTION_TRAINEE_TASKS=31d92e6818f880bd8d82e3ad97edd8f5

# ── Google Calendar ────────────────────────────────────────────
GOOGLE_CREDENTIALS_JSON=credentials.json
GOOGLE_TOKEN_JSON=token.json
GOOGLE_CALENDAR_ID=primary
# Set to 1 to skip Calendar entirely (e.g. scripts/verify_tools.py sets this; useful if credentials.json exists but you want a fast headless check).
# BELLA_DISABLE_CALENDAR=0

# ── Server ─────────────────────────────────────────────────────
PORT=3001
MCP_HOST=0.0.0.0

# Notion read tools cache (same args = instant hit until TTL or a write invalidates).
# Seconds: positive number. never = no expiry (writes still invalidate). 0 or off = disabled.
NOTION_TOOL_CACHE_TTL_SECONDS=3600

# Seconds — httpx read timeout per Notion API request (many requests per big page).
NOTION_HTTP_READ_TIMEOUT=180

# Parallel branches when fetching nested blocks (1 = old sequential behavior).
NOTION_FETCH_PARALLELISM=6

# ── Token / search tuning (optional) ────────────────────────────
# Obsidian: max matches returned per obsidian_search (default 30, max 200).
# BELLA_OBSIDIAN_SEARCH_MAX_RESULTS=30

# Web fetch body cap in characters (default 20000, max 200000).
# BELLA_WEB_FETCH_MAX_CHARS=20000

# Web search: default result count per call (default 4) and hard ceiling (default 10, max 20).
# BELLA_WEB_SEARCH_DEFAULT_RESULTS=4
# BELLA_WEB_SEARCH_MAX_RESULTS=10

# ── Obsidian vault (required for Obsidian + wiki MCP tools) ───────
# Docker Compose mounts your vault to /app/obsidian-vault — use that path here:
#   OBSIDIAN_VAULT_PATH=/app/obsidian-vault
# Local dev (no Docker): absolute path to your vault root, e.g.:
#   OBSIDIAN_VAULT_PATH=/Users/yousef/Documents/Obsidian Vault
# If unset, wiki_get_index / obsidian_* tools are not registered.

# OBSIDIAN_VAULT_PATH=/app/obsidian-vault

# ── LLM provider keys (optional, if your MCP client needs them) ─
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_API_KEY=
# BELLA_CHAT_MODEL=gpt-4o-mini
# BELLA_CHAT_HOST=0.0.0.0
# BELLA_CHAT_PORT=3002
